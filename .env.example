# ─────────────────────────────────────────────────────────────
# Nebula — пример переменных окружения.
# Скопируйте в .env и заполните. Значения валидируются Zod при старте.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=Nebula

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=nebula
POSTGRES_PASSWORD=nebula_dev_password
POSTGRES_DB=nebula
POSTGRES_PORT=5432
# Для приложения (внутри docker host = "postgres", локально = "localhost")
DATABASE_URL=postgresql://nebula:nebula_dev_password@localhost:5432/nebula?schema=public

# ── Redis ────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── MinIO (S3-совместимое хранилище) ─────────────────────────
MINIO_ROOT_USER=nebula
MINIO_ROOT_PASSWORD=nebula_dev_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=nebula-media
S3_ACCESS_KEY=nebula
S3_SECRET_KEY=nebula_dev_password
S3_REGION=us-east-1

# ── Auth (Auth.js) ───────────────────────────────────────────
# сгенерируйте: openssl rand -base64 32
AUTH_SECRET=change_me_generate_a_32_byte_base64_secret
AUTH_URL=http://localhost:3000
# Время жизни access-токена и refresh-токена (сек)
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600

# ── Realtime (Socket.IO сервис) ──────────────────────────────
REALTIME_PORT=4000
REALTIME_URL=http://localhost:4000
NEXT_PUBLIC_REALTIME_URL=http://localhost:4000

# ── Платежи (ЮKassa) ─────────────────────────────────────────
# Оставьте PAYMENT_PROVIDER=mock для разработки без боевых реквизитов.
PAYMENT_PROVIDER=mock
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# return_url формируется на заказ автоматически (APP_URL/orders/:id).
# Webhook в личном кабинете ЮKassa указывайте на: APP_URL/api/webhooks/payment

# ── Email ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=no-reply@nebula.local

# ── Наблюдаемость (опционально) ──────────────────────────────
SENTRY_DSN=
LOG_LEVEL=debug
