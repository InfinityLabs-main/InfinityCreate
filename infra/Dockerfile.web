# ── Multi-stage сборка Next.js (standalone) ──────────────────
FROM node:20-alpine AS base
RUN corepack enable && apk add --no-cache libc6-compat openssl
WORKDIR /app

# ── deps ──
FROM base AS deps
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY apps/web/package.json apps/web/
COPY packages/db/package.json packages/db/
RUN pnpm install --frozen-lockfile || pnpm install

# ── build ──
FROM base AS build
# Полное дерево node_modules воркспейса (pnpm-симлинки) из deps-слоя.
COPY --from=deps /app/ ./
COPY . .
RUN pnpm --filter @nebula/db generate
RUN pnpm --filter @nebula/web build

# ── runner ──
FROM base AS runner
ENV NODE_ENV=production
RUN addgroup -g 1001 nodejs && adduser -u 1001 -G nodejs -S nextjs
COPY --from=build --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=build --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=build --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public
# Prisma query-engine (.so.node) включается в standalone через
# outputFileTracingIncludes в next.config.mjs — отдельное копирование не нужно.
USER nextjs
EXPOSE 3000
ENV PORT=3000 HOSTNAME=0.0.0.0
CMD ["node", "apps/web/server.js"]
